<assembly xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.2"
          xsi:schemaLocation="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.2 http://maven.apache.org/xsd/assembly-1.1.2.xsd">
    <!-- ID wird an den Artefaktnamen angehängt: artifact-{id}.zip -->
    <id>distribution</id>

    <formats>
        <format>zip</format>
    </formats>

    <!-- false = kein zusätzliches Wurzelverzeichnis im Archiv -->
    <includeBaseDirectory>false</includeBaseDirectory>

    <fileSets>
        <!-- ARCHIV-BESTAND mit allen Phasen (PHASE-1, PHASE-2, etc.) -->
        <fileSet>
            <directory>${basedir}/../test_set/ARCHIV-BESTAND</directory>
            <outputDirectory>/ARCHIV-BESTAND</outputDirectory>
            <includes>
                <include>**/*</include>
            </includes>
        </fileSet>
        <!-- REF-EXPORTS mit allen Phasen und Kandidaten -->
        <fileSet>
            <directory>${basedir}/../test_set/REF-EXPORTS</directory>
            <outputDirectory>/REF-EXPORTS</outputDirectory>
            <includes>
                <include>**/*</include>
            </includes>
        </fileSet>
    </fileSets>

</assembly>
